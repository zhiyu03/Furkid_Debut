# === Replicate (gpt-image-2) — 变装合成 ===
# https://replicate.com/account/api-tokens
# 变量名须完全一致：REPLICATE_API_TOKEN（不要写在 client/.env 里，服务端才读得到）
# 若同时存在 server/.env 与本文件，以 server/.env 为准；勿在 server/.env 里留空一行 REPLICATE_API_TOKEN=
REPLICATE_API_TOKEN=

# 公网可访问的服务根 URL（无尾部斜杠）。Replicate 需能拉取 /uploads 下的原图。
# 勿填 http://127.0.0.1 或 localhost：云端会把 127.0.0.1 当成「它自己」，必然 Connection refused。
# 本地开发请用 ngrok / cloudflared 等，例如: https://xxxx.ngrok-free.app
PUBLIC_BASE_URL=

# 可选：gpt-image-2 仅允许 1:1 | 3:2 | 2:3（竖屏用 2:3）
# DEBUT_ASPECT_RATIO=2:3

# === Server ===
PORT=3001

# === 旧版端点（已废弃，仍可用 mock）===
IMAGE_API_URL=
IMAGE_API_KEY=
VISION_API_URL=
VISION_API_KEY=
